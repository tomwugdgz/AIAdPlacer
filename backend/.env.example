# ═══════════════════════════════════════════════════════════════
# pDOOH 服务端环境变量配置
# ═══════════════════════════════════════════════════════════════
# 本文件是环境变量配置模板，请按以下步骤使用：
# 1. 复制本文件为 .env（保留本文件作为参考）
# 2. 根据实际情况修改各配置项
# 3. 不要将包含真实密钥的 .env 文件提交到 Git
# ═══════════════════════════════════════════════════════════════

# ── 数据库配置 ─────────────────────────────────────────────────────
# 主数据库连接字符串
# SQLite（默认，无需额外安装）:
#   DATABASE_URL=sqlite:///./pdooh.db
# PostgreSQL（生产环境推荐）:
#   DATABASE_URL=postgresql://username:password@localhost:5432/dbname
DATABASE_URL=sqlite:///./pdooh.db

# Redis 连接（用于缓存和异步任务）
# 本地 Redis: redis://127.0.0.1:6379/0
# 远程 Redis: redis://:password@host:port/db
REDIS_URL=redis://127.0.0.1:6379/0

# ── 腾讯地图 API Key ──────────────────────────────────────────────
# 用于地理位置查询、经纬度转换等功能
# 申请地址: https://lbs.qq.com/
# 如果不使用地理位置功能，可留空
TENCENT_MAP_KEY=your_tencent_map_key_here

# ── 调试模式 ─────────────────────────────────────────────────────
# true: 启用调试模式（显示详细错误信息、热重载）
# false: 生产模式（性能优化、隐藏错误详情）
DEBUG=true

# ── LLM 配置（AI 大模型）─────────────────────────────────────
# LLM 提供商选项:
#   - ollama: 本地运行（免费，默认）
#   - openai: OpenAI API（需要 API Key）
#   - anthropic: Anthropic Claude（需要 API Key）
#   - custom: 自定义 OpenAI 兼容接口
LLM_PROVIDER=ollama

# ── Ollama 配置（本地 LLM）────────────────────────────────────
# Ollama 服务地址（默认: http://127.0.0.1:11434）
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Ollama 模型名称（需要先拉取模型: ollama pull qwen2.5:latest）
# 推荐模型:
#   - qwen2.5:latest (通义千问，中文友好)
#   - llama3.1:latest (Meta Llama，英文友好)
#   - deepseek-r1:latest (深度求索，推理能力强)
OLLAMA_MODEL=qwen2.5:latest

# ── OpenAI 配置（如使用 OpenAI）───────────────────────────────
# OpenAI API Key（以 sk- 开头）
# OPENAI_API_KEY=sk-your_openai_key_here
# OpenAI 模型名称
#   - gpt-4o: 最新多模态模型（推荐）
#   - gpt-4-turbo: 高性能模型
#   - gpt-3.5-turbo: 经济实惠
# OPENAI_MODEL=gpt-4o
# OpenAI API Base URL（可选，用于代理或 Azure OpenAI）
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic 配置（如使用 Claude）────────────────────────────
# Anthropic API Key（以 sk-ant- 开头）
# ANTHROPIC_API_KEY=sk-ant-your_key_here
# Claude 模型名称
#   - claude-3-5-sonnet-20241022: 最新 Sonnet 模型（推荐）
#   - claude-3-opus-20240229: 最强模型
#   - claude-3-haiku-20240307: 最快模型
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── LLM 开关 ────────────────────────────────────────────────────
# true: 启用 LLM（Tom Agent 将调用大模型生成回复）
# false: 禁用 LLM（Tom Agent 将使用规则降级方案，无需 LLM）
LLM_ENABLED=true

# ── 服务端口配置 ──────────────────────────────────────────────
# 各 Agent 服务端口（默认即可，如无端口冲突无需修改）
MCP_SERVER_PORT=5002
TOM_AGENT_PORT=5003
ROI_AGENT_PORT=5004
COMPETITOR_AGENT_PORT=5005

# ── 日志配置 ──────────────────────────────────────────────────
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# 日志文件目录（相对 backend/ 目录）
LOG_DIR=logs

# ── 知识库配置 ────────────────────────────────────────────────
# 知识库数据存储目录（用于 MCP 调用结果归档）
KNOWLEDGE_DIR=data/knowledge

# ── ChromaDB 配置（向量数据库）──────────────────────────────
# ChromaDB 持久化目录
CHROMA_PERSIST_DIR=./chroma_db
# 向量模型名称（用于文本嵌入）
# 推荐模型:
#   - all-MiniLM-L6-v2 (快速，英文)
#   - paraphrase-multilingual-MiniLM-L12-v2 (多语言，推荐)
#   - BAAI/bge-large-zh-v1.5 (中文，效果好)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ═══════════════════════════════════════════════════════════════
# 配置说明总结
# ═══════════════════════════════════════════════════════════════
# 
# 最小配置（快速启动）:
#   1. 保持 LLM_ENABLED=false（无需配置大模型）
#   2. 保持 DATABASE_URL=sqlite:///./pdooh.db（无需安装数据库）
#   3. 运行 install.bat 安装依赖
#   4. 运行 start_all.bat 启动服务
#
# 完整配置（启用 AI 功能）:
#   1. 安装 Ollama: https://ollama.com/
#   2. 拉取模型: ollama pull qwen2.5:latest
#   3. 设置 LLM_ENABLED=true
#   4. 运行 start_all.bat 启动服务
#
# 生产环境配置:
#   1. 使用 PostgreSQL 替换 SQLite
#   2. 使用 Redis 服务替换默认配置
#   3. 设置 DEBUG=false
#   4. 配置 OpenAI 或 Anthropic API Key
# ═══════════════════════════════════════════════════════════════
