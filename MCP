六、Python SDK 调用示例
import requests

BASE_URL = "http://47.253.159.62:5002"

**1. 查询智能屏**
def query_screens(city, district, limit=10):
    response = requests.post(
        f"{BASE_URL}/api/v2/mcp/pdooh/tools/call",
        json={
            "name": "pdooh_query_screens",
            "arguments": {
                "city": city,
                "district": district,
                "limit": limit
            }
        }
    )
    return response.json()

**2. 创建投放计划**
def create_campaign(name, screen_ids, budget, start_date, end_date):
    response = requests.post(
        f"{BASE_URL}/api/v2/mcp/pdooh/tools/call",
        json={
            "name": "pdooh_create_campaign",
            "arguments": {
                "name": name,
                "screen_ids": screen_ids,
                "budget": budget,
                "start_date": start_date,
                "end_date": end_date
            }
        }
    )
    return response.json()

**3. 调用 Agent 编排**
def execute_agent(task, agent="audience"):
    response = requests.post(
        f"{BASE_URL}/api/v2/agents/execute",
        json={"task": task, "agent": agent}
    )
    return response.json()

**使用**
screens = query_screens("广州", "天河区")
campaign = create_campaign(
    name="高端白酒-天河城-周投",
    screen_ids=[1, 2, 3],
    budget=30000,
    start_date="2026-06-10",
    end_date="2026-06-16"
)
result = execute_agent("帮我在广州天河区投放高端白酒广告")

